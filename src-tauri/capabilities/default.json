{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "os:default",
    "deep-link:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*.kintone.com/*" },
        { "url": "https://*.cybozu.com/*" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.kintone.com" },
        { "url": "https://*.cybozu.com" }
      ]
    }
  ]
}